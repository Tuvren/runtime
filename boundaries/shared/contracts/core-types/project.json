{
  "name": "shared-core-types",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/shared/contracts/core-types",
  "sourceRoot": "boundaries/shared/contracts/core-types/src",
  "projectType": "library",
  "tags": ["boundary:shared", "layer:contract"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/shared/contracts/core-types",
        "commands": [
          {
            "command": "bunx --bun tsup --config tsup.config.ts"
          },
          {
            "command": "bunx --bun tsc --project tsconfig.dts.json --pretty false"
          }
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/shared/contracts/core-types",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/shared/contracts/core-types",
        "command": "tsc --project tsconfig.lib.json --noEmit --pretty false"
      }
    }
  }
}
