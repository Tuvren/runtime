{
  "name": "shared-core",
  "$schema": "../../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/shared/contracts/core/implementations/typescript",
  "sourceRoot": "boundaries/shared/contracts/core/implementations/typescript/src",
  "projectType": "library",
  "tags": ["boundary:shared", "layer:contract"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/shared/contracts/core/implementations/typescript",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/boundaries/shared/contracts/core/artifacts/json-schema"
      ],
      "options": {
        "cwd": "boundaries/shared/contracts/core",
        "command": "bunx --bun tsp compile ./spec/typespec --pretty false && bunx --bun @biomejs/biome check --write ./artifacts"
      },
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/boundaries/shared/contracts/core/spec/**/*",
        "{workspaceRoot}/boundaries/shared/contracts/core/artifacts/**/*"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/shared/contracts/core/implementations/typescript"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/shared/contracts/core/implementations/typescript",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/shared/contracts/core/implementations/typescript",
        "command": "tsc --project tsconfig.lib.json --noEmit --pretty false"
      }
    }
  }
}
