          "output": {},
          "isError": {
            "type": "boolean"
          },
          "providerMetadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "TuvrenJsonSchema": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/TuvrenJsonSchemaObject"
          },
          {
            "type": "boolean"
          }
        ]
      },
      "TuvrenJsonSchemaObject": {
        "type": "object",
        "unevaluatedProperties": {}
      },
      "TuvrenMessage": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/SystemMessage"
          },
          {
            "$ref": "#/components/schemas/UserMessage"
          },
          {
            "$ref": "#/components/schemas/AssistantMessage"
          },
          {
            "$ref": "#/components/schemas/ToolMessage"
          }
        ]
      },
      "TuvrenModelConfig": {
        "type": "object",
        "properties": {
          "model": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "provider": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "settings": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "TuvrenModelResponse": {
        "type": "object",
        "required": ["finishReason", "parts"],
        "properties": {
          "finishReason": {
            "$ref": "#/components/schemas/FinishReason"
          },
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentPart"
            }
          },
          "usage": {
            "$ref": "#/components/schemas/ProviderUsage"
          },
          "providerMetadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
