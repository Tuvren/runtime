        "type": "object",
        "required": ["messages"],
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TuvrenMessage"
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RenderedToolDefinition"
            }
          },
          "config": {
            "$ref": "#/components/schemas/TuvrenModelConfig"
          },
          "responseFormat": {
            "$ref": "#/components/schemas/StructuredOutputRequest"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "UserMessage": {
        "type": "object",
        "required": ["role", "parts"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["user"]
          },
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentPart"
            },
            "minItems": 1
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      }
