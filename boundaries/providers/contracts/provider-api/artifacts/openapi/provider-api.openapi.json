          "providerCallId": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "delta": {
            "type": "string"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "ToolCallDoneChunk": {
        "type": "object",
        "required": ["type", "providerCallId", "name", "input"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["tool_call_done"]
          },
          "providerCallId": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "name": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "input": {},
          "providerMetadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "ToolCallPart": {
        "type": "object",
        "required": ["type", "callId", "name", "input"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["tool_call"]
          },
          "callId": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "name": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "input": {},
          "providerMetadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "ToolCallStartChunk": {
        "type": "object",
        "required": ["type", "providerCallId", "name"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["tool_call_start"]
          },
          "providerCallId": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "name": {
            "$ref": "#/components/schemas/NonEmptyString"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "ToolMessage": {
        "type": "object",
        "required": ["role", "parts"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["tool"]
          },
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolResultPart"
            },
            "minItems": 1
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "ToolResultPart": {
        "type": "object",
        "required": ["type", "callId", "name", "output"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["tool_result"]
