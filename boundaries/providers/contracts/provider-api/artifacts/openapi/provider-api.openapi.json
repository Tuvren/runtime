          "data": {},
          "name": {
            "$ref": "#/components/schemas/NonEmptyString"
          },
          "providerMetadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "SystemMessage": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system"]
          },
          "content": {
            "$ref": "#/components/schemas/NonEmptyString"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "TextDeltaChunk": {
        "type": "object",
        "required": ["type", "text"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["text_delta"]
          },
          "text": {
            "type": "string"
          }
        },
        "unevaluatedProperties": {
          "not": {}
        }
      },
      "TextPart": {
        "type": "object",
        "required": ["type", "text"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["text"]
          },
          "text": {
            "type": "string"
