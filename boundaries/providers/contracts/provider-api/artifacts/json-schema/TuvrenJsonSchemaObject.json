                  "object",
                  "array",
                  "number",
                  "integer",
                  "string"
                ]
              },
              {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "enum": [
                    "null",
                    "boolean",
                    "object",
                    "array",
                    "number",
                    "integer",
                    "string"
                  ]
                }
              }
            ]
          }
        }
      }
    }
  ],
  "$comment": "Opaque JSON Schema carrier. This artifact validates portable container shape and selected runtime keyword guards, but it is not a full JSON Schema metaschema replacement."
}
