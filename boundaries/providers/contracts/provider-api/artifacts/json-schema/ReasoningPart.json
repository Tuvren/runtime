{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/providers/provider-api/ReasoningPart.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "reasoning"
    },
    "text": {
      "type": "string"
    },
    "redacted": {
      "type": "boolean"
    },
    "providerMetadata": {
      "$ref": "https://tuvren.dev/schemas/providers/provider-api/Metadata.json"
    }
  },
  "required": ["type", "text", "redacted"],
  "unevaluatedProperties": {
    "not": {}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "redacted": {
            "const": false
          }
        },
        "required": ["redacted"]
      },
      "then": {
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "pattern": ".*\\S.*"
          }
        }
      }
    }
  ]
}
