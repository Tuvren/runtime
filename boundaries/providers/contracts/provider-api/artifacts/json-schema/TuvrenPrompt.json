{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/providers/provider-api/TuvrenPrompt.json",
  "type": "object",
  "properties": {
    "messages": {
      "type": "array",
      "items": {
        "$ref": "https://tuvren.dev/schemas/providers/provider-api/TuvrenMessage.json"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "https://tuvren.dev/schemas/providers/provider-api/RenderedToolDefinition.json"
      }
    },
    "providerNativeTools": {
      "type": "array",
      "items": {
        "$ref": "https://tuvren.dev/schemas/providers/provider-api/ProviderNativeToolDeclaration.json"
      }
    },
    "providerMediatedTools": {
      "type": "array",
      "items": {
        "$ref": "https://tuvren.dev/schemas/providers/provider-api/ProviderMediatedToolConfig.json"
      }
    },
    "providerContinuity": {
      "$ref": "https://tuvren.dev/schemas/providers/provider-api/Metadata.json"
    },
    "config": {
      "$ref": "https://tuvren.dev/schemas/providers/provider-api/TuvrenModelConfig.json"
    },
    "responseFormat": {
      "$ref": "https://tuvren.dev/schemas/providers/provider-api/StructuredOutputRequest.json"
    }
  },
  "required": ["messages"],
  "unevaluatedProperties": {
    "not": {}
  },
  "$comment": "The TypeScript binding additionally carries a non-serializable cooperative-cancellation `signal` out-of-band so the framework execution-bounds guard (ADR-043) can abort an in-flight model request at maxWallClockMs. It is intentionally absent from this JSON payload schema; owned bridges forward it to the underlying provider call."
}
