{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@kraken/shared-core-types": [
        "../../../shared/contracts/core-types/dist/index.d.ts"
      ],
      "@kraken/framework-runtime-api": [
        "../../../framework/contracts/runtime-api/dist/index.d.ts"
      ],
      "@kraken/provider-api": ["./src/index.ts"]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
