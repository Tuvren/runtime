{
  "name": "providers-typescript-conformance-runner",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/providers/implementations/typescript/conformance-runner",
  "projectType": "library",
  "tags": [
    "boundary:providers",
    "language:typescript",
    "layer:conformance-runner"
  ],
  "targets": {
    "conformance": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/providers/implementations/typescript/conformance-runner",
        "command": "bun test ./test/providers-typescript-conformance.test.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/providers/implementations/typescript/conformance-runner"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/providers/implementations/typescript/conformance-runner",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/providers/implementations/typescript/conformance-runner",
        "command": "bunx --bun tsc --project tsconfig.typecheck.json --noEmit --pretty false"
      }
    }
  }
}
