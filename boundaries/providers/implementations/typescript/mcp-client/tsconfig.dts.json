{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/core": [
        "../../../../shared/contracts/core/implementations/typescript/dist/index.d.ts"
      ],
      "@tuvren/core/errors": [
        "../../../../shared/contracts/core/implementations/typescript/dist/errors/index.d.ts"
      ],
      "@tuvren/core/tools": [
        "../../../../shared/contracts/core/implementations/typescript/dist/tools/index.d.ts"
      ]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
