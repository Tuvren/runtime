{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/core-types": [
        "../../../../shared/contracts/core-types/dist/index.d.ts"
      ],
      "@tuvren/provider-api": [
        "../../../contracts/provider-api/dist/index.d.ts"
      ],
      "@tuvren/runtime-api": [
        "../../../../framework/contracts/runtime-api/dist/index.d.ts"
      ],
      "@tuvren/runtime-api/events": [
        "../../../../framework/contracts/runtime-api/dist/events.d.ts"
      ],
      "@tuvren/runtime-api/execution": [
        "../../../../framework/contracts/runtime-api/dist/execution.d.ts"
      ],
      "@tuvren/runtime-api/provider": [
        "../../../../framework/contracts/runtime-api/dist/provider.d.ts"
      ],
      "@tuvren/runtime-api/tools": [
        "../../../../framework/contracts/runtime-api/dist/tools.d.ts"
      ]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
