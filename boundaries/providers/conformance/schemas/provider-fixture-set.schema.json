{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/providers/conformance/provider-fixture-set.schema.json",
  "$defs": {
    "contentPart": {
      "oneOf": [
        {
          "type": "object",
          "required": ["text", "type"],
          "properties": {
            "providerMetadata": {
              "type": "object",
              "additionalProperties": true
            },
            "text": { "type": "string" },
            "type": { "const": "text" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["redacted", "text", "type"],
          "properties": {
            "providerMetadata": {
              "type": "object",
              "additionalProperties": true
            },
            "redacted": { "type": "boolean" },
            "text": { "type": "string" },
            "type": { "const": "reasoning" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["callId", "input", "name", "type"],
          "properties": {
            "callId": { "type": "string", "minLength": 1 },
            "input": true,
            "name": { "type": "string", "minLength": 1 },
            "providerMetadata": {
              "type": "object",
              "additionalProperties": true
            },
            "type": { "const": "tool_call" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["callId", "name", "output", "type"],
          "properties": {
            "callId": { "type": "string", "minLength": 1 },
            "isError": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 },
            "output": true,
            "providerMetadata": {
              "type": "object",
              "additionalProperties": true
            },
            "type": { "const": "tool_result" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["data", "mediaType", "type"],
          "properties": {
            "data": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                }
              ]
            },
            "filename": { "type": "string" },
            "mediaType": { "type": "string", "minLength": 1 },
            "providerMetadata": {
              "type": "object",
              "additionalProperties": true
            },
            "type": { "const": "file" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["data", "type"],
          "properties": {
            "data": true,
            "name": { "type": "string", "minLength": 1 },
            "providerMetadata": {
              "type": "object",
              "additionalProperties": true
            },
            "type": { "const": "structured" }
          },
          "additionalProperties": false
        }
      ]
    },
    "messageParts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contentPart" }
    },
    "structuredOutputRequest": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "schema": true,
        "strict": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "toolDefinition": {
      "type": "object",
      "required": ["description", "inputSchema", "name"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "inputSchema": true,
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "tuvrenMessage": {
      "oneOf": [
        {
          "type": "object",
          "required": ["content", "role"],
          "properties": {
            "content": { "type": "string" },
            "role": { "const": "system" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["parts", "role"],
          "properties": {
            "parts": { "$ref": "#/$defs/messageParts" },
            "role": { "const": "user" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["parts", "role"],
          "properties": {
            "parts": { "$ref": "#/$defs/messageParts" },
            "providerMetadata": {
              "type": "object",
              "additionalProperties": true
            },
            "role": { "const": "assistant" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["parts", "role"],
          "properties": {
            "parts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["callId", "name", "output", "type"],
                "properties": {
                  "callId": { "type": "string", "minLength": 1 },
                  "isError": { "type": "boolean" },
                  "name": { "type": "string", "minLength": 1 },
                  "output": true,
                  "providerMetadata": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "type": { "const": "tool_result" }
                },
                "additionalProperties": false
              }
            },
            "role": { "const": "tool" }
          },
          "additionalProperties": false
        }
      ]
    },
    "tuvrenPrompt": {
      "type": "object",
      "required": ["messages"],
      "properties": {
        "config": {
          "type": "object",
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "provider": { "type": "string", "minLength": 1 },
            "settings": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        },
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/tuvrenMessage" }
        },
        "responseFormat": { "$ref": "#/$defs/structuredOutputRequest" },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolDefinition" }
        }
      },
      "additionalProperties": false
    },
    "tuvrenModelResponse": {
      "type": "object",
      "required": ["finishReason", "parts"],
      "properties": {
        "finishReason": {
          "enum": ["stop", "tool_call", "length", "error", "content_filter"]
        },
        "parts": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentPart" }
        },
        "providerMetadata": { "type": "object", "additionalProperties": true },
        "usage": {
          "type": "object",
          "required": ["inputTokens", "outputTokens"],
          "properties": {
            "inputTokens": { "type": "number" },
            "outputTokens": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": ["prompt", "response", "structuredPrompt", "toolPrompt"],
  "properties": {
    "prompt": { "$ref": "#/$defs/tuvrenPrompt" },
    "response": { "$ref": "#/$defs/tuvrenModelResponse" },
    "structuredPrompt": { "$ref": "#/$defs/tuvrenPrompt" },
    "toolPrompt": { "$ref": "#/$defs/tuvrenPrompt" }
  },
  "additionalProperties": false
}
