{
  "name": "host-playground",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/hosts/implementations/typescript/playground",
  "sourceRoot": "boundaries/hosts/implementations/typescript/playground/src",
  "projectType": "application",
  "tags": ["boundary:hosts", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "exports-smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "bun test ./smoke/package-exports.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/hosts/implementations/typescript/playground"
      }
    },
    "scenario": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "node dist/cli.js"
      }
    },
    "scenario-gemini": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "^build"],
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "bun dist/gemini-cli.js --provider ai-sdk-google"
      }
    },
    "scenario-sqlite": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "node dist/cli.js --scenario reload --backend sqlite --provider fixture --sqlite-path auto"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "^build"],
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "bun test"
      }
    },
    "test-local": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/hosts/implementations/typescript/playground",
        "command": "bunx --bun tsc --project tsconfig.lib.json --noEmit --pretty false && bunx --bun tsc --project tsconfig.typecheck.json --noEmit --pretty false && bunx --bun tsc --project tsconfig.dts.json --noEmit --pretty false"
      }
    }
  }
}
