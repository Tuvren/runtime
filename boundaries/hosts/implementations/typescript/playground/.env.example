# Playground provider mode:
# - fixture
# - ai-sdk-mock
# - aimock-openai
# - aimock-anthropic
# - aimock-google
# - ai-sdk-google
TUVREN_PLAYGROUND_PROVIDER_MODE=ai-sdk-google

# Playground scenario:
# - streaming
# - structured
# - tools
# - approval
# - cancel
# - metadata
# - branching
# - steering
# - reload
TUVREN_PLAYGROUND_SCENARIO=streaming

# Optional Gemini model override for ai-sdk-google mode.
TUVREN_PLAYGROUND_MODEL_ID=gemini-2.5-flash

# Optional backend selection.
TUVREN_PLAYGROUND_BACKEND=memory

# Optional SQLite database path for --backend sqlite. Use "auto" for disposable smoke DBs.
TUVREN_PLAYGROUND_SQLITE_PATH=auto

# Required for aimock-openai, aimock-anthropic, and aimock-google modes.
# Use the provider-compatible base path:
# - OpenAI / Anthropic: http://127.0.0.1:4010/v1
# - Gemini:             http://127.0.0.1:4010/v1beta
TUVREN_PLAYGROUND_AIMOCK_BASE_URL=http://127.0.0.1:4010/v1

# Gemini credentials for ai-sdk-google mode. The playground reads
# GOOGLE_GENERATIVE_AI_API_KEY first and falls back to GEMINI_API_KEY.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=
