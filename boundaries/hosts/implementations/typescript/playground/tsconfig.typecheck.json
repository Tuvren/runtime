        "../../../../framework/implementations/typescript/drivers/react/src/index.ts"
      ],
      "@tuvren/event-stream": [
        "../../../../framework/contracts/event-stream/implementations/typescript/src/index.ts"
      ],
      "@tuvren/framework-testkit": [
        "../../../../framework/implementations/typescript/testkit/src/index.ts"
      ],
      "@tuvren/kernel-protocol": [
        "../../../../kernel/contracts/protocol/implementations/typescript/src/index.ts"
