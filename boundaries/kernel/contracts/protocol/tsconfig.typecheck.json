{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": [
        "../../../shared/contracts/core-types/src/index.ts"
      ],
      "@tuvren/runtime-api": [
        "../../../framework/contracts/runtime-api/src/index.ts"
      ],
      "@tuvren/kernel-protocol": ["./src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../../../shared/contracts/core-types/src/**/*.ts",
    "../../../framework/contracts/runtime-api/src/**/*.ts",
    "../../../../tests/fixtures/**/*.ts"
  ]
}
