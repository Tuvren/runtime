{
  "name": "kernel-contract-protocol",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/contracts/protocol",
  "sourceRoot": "boundaries/kernel/contracts/protocol/src",
  "projectType": "library",
  "tags": ["boundary:kernel", "layer:contract"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/contracts/protocol",
        "commands": [
          {
            "command": "bunx --bun tsup --config tsup.config.ts"
          },
          {
            "command": "tsc --project tsconfig.lib.json --emitDeclarationOnly --declaration --declarationMap --pretty false"
          }
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/contracts/protocol",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/contracts/protocol",
        "commands": [
          {
            "command": "tsc --project tsconfig.lib.json --noEmit --pretty false"
          },
          {
            "command": "tsc --project tsconfig.typecheck.json --noEmit --pretty false"
          }
        ],
        "parallel": false
      }
    }
  }
}
