{
  "name": "kernel-contract-protocol",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/contracts/protocol",
  "sourceRoot": "boundaries/kernel/contracts/protocol/src",
  "projectType": "library",
  "tags": ["boundary:kernel", "layer:contract"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/kernel/contracts/protocol",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "bench": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/contracts/protocol",
        "command": "bun bench/kernel-identity.bench.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/kernel/contracts/protocol"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/contracts/protocol",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/kernel/contracts/protocol",
        "command": "tsc --project tsconfig.lib.json --noEmit --pretty false && tsc --project tsconfig.typecheck.json --noEmit --pretty false"
      }
    }
  }
}
