{
  "name": "kernel-rust-grpc-service",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/implementations/rust/grpc-service",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:rust", "layer:interop"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "devenv shell -- cargo build -p tuvren-kernel-rust-grpc-service"
      }
    },
    "interop-smoke": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "devenv shell -- cargo test -p tuvren-kernel-rust-grpc-service --test interop_smoke"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "devenv shell -- cargo fmt --package tuvren-kernel-rust-grpc-service -- --check && devenv shell -- cargo clippy -p tuvren-kernel-rust-grpc-service --all-targets -- -D warnings"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "devenv shell -- cargo test -p tuvren-kernel-rust-grpc-service"
      }
    }
  }
}
