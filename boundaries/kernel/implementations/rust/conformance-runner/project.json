{
  "name": "kernel-rust-conformance-runner",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/implementations/rust/conformance-runner",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:rust", "layer:conformance-runner"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo build -p tuvren-kernel-rust-conformance-runner"
      }
    },
    "conformance": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo run -p tuvren-kernel-rust-conformance-runner"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo fmt --package tuvren-kernel-rust-conformance-runner -- --check && cargo clippy -p tuvren-kernel-rust-conformance-runner --all-targets -- -D warnings"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo test -p tuvren-kernel-rust-conformance-runner"
      }
    }
  }
}
