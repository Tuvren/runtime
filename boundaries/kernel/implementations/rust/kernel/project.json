{
  "name": "kernel-rust-kernel",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/implementations/rust/kernel",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:rust", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "devenv shell -- cargo build -p tuvren-kernel-rust"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "devenv shell -- cargo fmt --package tuvren-kernel-rust -- --check && devenv shell -- cargo clippy -p tuvren-kernel-rust --all-targets -- -D warnings"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "devenv shell -- cargo test -p tuvren-kernel-rust"
      }
    }
  }
}
