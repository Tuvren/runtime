{
  "name": "kernel-runtime",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/implementations/typescript/runtime-kernel",
  "sourceRoot": "boundaries/kernel/implementations/typescript/runtime-kernel/src",
  "projectType": "library",
  "tags": ["boundary:kernel", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/kernel/implementations/typescript/runtime-kernel",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/kernel/implementations/typescript/runtime-kernel"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/implementations/typescript/runtime-kernel",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/kernel/implementations/typescript/runtime-kernel",
        "command": "bunx --bun tsc --project tsconfig.lib.json --noEmit --pretty false && bunx --bun tsc --project tsconfig.typecheck.json --noEmit --pretty false"
      }
    }
  }
}
