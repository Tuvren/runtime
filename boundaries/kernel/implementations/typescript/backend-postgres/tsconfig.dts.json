{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/core-types": [
        "../../../../shared/contracts/core-types/implementations/typescript/dist/index.d.ts"
      ],
      "@tuvren/kernel-protocol": [
        "../../../contracts/protocol/implementations/typescript/dist/index.d.ts"
      ],
      "@tuvren/backend-postgres": ["./src/index.ts"]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
