{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": [
        "../../../../shared/contracts/core-types/src/index.ts"
      ],
      "@tuvren/kernel-protocol": ["../../../contracts/protocol/src/index.ts"],
      "@tuvren/kernel-testkit": ["../../../testkit/src/index.ts"],
      "@tuvren/backend-memory": ["./src/index.ts"]
    },
    "types": ["bun", "node"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../../../contracts/protocol/src/**/*.ts",
    "../../../testkit/src/**/*.ts",
    "../../../../shared/contracts/core-types/src/**/*.ts"
  ]
}
