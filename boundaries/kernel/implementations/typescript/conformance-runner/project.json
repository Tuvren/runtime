{
  "name": "kernel-typescript-conformance-runner",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/implementations/typescript/conformance-runner",
  "projectType": "library",
  "tags": [
    "boundary:kernel",
    "language:typescript",
    "layer:conformance-runner"
  ],
  "targets": {
    "conformance": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": [
            "backend-memory",
            "kernel-runtime",
            "kernel-typescript-conformance-adapter"
          ],
          "target": "build",
          "params": "ignore"
        }
      ],
      "options": {
        "cwd": ".",
        "command": "bun tools/conformance/runner/run.ts --adapter boundaries/kernel/implementations/typescript/conformance-adapter/adapter.json --concurrency 4 --summary-only"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/kernel/implementations/typescript/conformance-runner"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/implementations/typescript/conformance-runner",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts boundaries/kernel/implementations/typescript/conformance-runner"
      }
    }
  }
}
