{
  "name": "kernel-testkit",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/kernel/testkit",
  "sourceRoot": "boundaries/kernel/testkit/src",
  "projectType": "library",
  "tags": ["boundary:kernel", "layer:testkit"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/kernel/testkit",
        "commands": [
          {
            "command": "bunx --bun tsup --config tsup.config.ts"
          },
          {
            "command": "bunx --bun tsc --project tsconfig.dts.json --pretty false"
          }
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/testkit",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/kernel/testkit",
        "commands": [
          {
            "command": "bunx --bun tsc --project tsconfig.lib.json --noEmit --pretty false"
          },
          {
            "command": "bunx --bun tsc --project tsconfig.typecheck.json --noEmit --pretty false"
          }
        ],
        "parallel": false
      }
    }
  }
}
