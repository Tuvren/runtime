{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": ["../../shared/contracts/core-types/src/index.ts"],
      "@tuvren/kernel-protocol": ["../contracts/protocol/src/index.ts"]
    },
    "types": ["bun", "node"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../contracts/protocol/src/**/*.ts",
    "../../shared/contracts/core-types/src/**/*.ts"
  ]
}
