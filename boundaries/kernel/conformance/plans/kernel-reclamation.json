{
  "planId": "tuvren.kernel.reclamation",
  "planVersion": "0.2.0",
  "packetId": "tuvren.kernel.protocol",
  "applicability": {
    "capabilities": ["kernel.reclamation"]
  },
  "checks": [
    {
      "checkId": "kernel.reclamation.unreachable_past_grace_is_released",
      "operation": "kernel.reclamation.reclaim-probe",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.reclaim.unreachablePastGraceReleased",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.reclaim.archivedBranchReleased",
          "equals": true
        }
      ],
      "evidence": [
        "reclaim.unreachablePastGraceReleased",
        "reclaim.archivedBranchReleased"
      ]
    },
    {
      "checkId": "kernel.reclamation.reachable_from_live_root_is_retained",
      "operation": "kernel.reclamation.reclaim-probe",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.reclaim.reachableFromLiveRootRetained",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.reclaim.sharedObjectRetainedViaLiveRoot",
          "equals": true
        }
      ],
      "evidence": [
        "reclaim.reachableFromLiveRootRetained",
        "reclaim.sharedObjectRetainedViaLiveRoot"
      ]
    },
    {
      "checkId": "kernel.reclamation.grace_window_holds_under_active_lease",
      "operation": "kernel.reclamation.reclaim-probe",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.reclaim.graceWindowHeldUnderActiveLease",
          "equals": true
        }
      ],
      "evidence": ["reclaim.graceWindowHeldUnderActiveLease"]
    },
    {
      "checkId": "kernel.reclamation.erasure_payload_unrecoverable_after_key_destruction",
      "operation": "kernel.reclamation.erasure-probe",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.erasure.recoverableBeforeErasure",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.erasure.unrecoverableAfterErasure",
          "equals": true
        }
      ],
      "evidence": [
        "erasure.recoverableBeforeErasure",
        "erasure.unrecoverableAfterErasure"
      ]
    },
    {
      "checkId": "kernel.reclamation.erasure_preserves_referencing_lineage",
      "operation": "kernel.reclamation.erasure-probe",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.erasure.lineageStructurallyIntactAfterErasure",
          "equals": true
        }
      ],
      "evidence": ["erasure.lineageStructurallyIntactAfterErasure"]
    }
  ]
}
