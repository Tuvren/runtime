{
  "name": "framework-typescript-conformance-runner",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/framework/implementations/typescript/conformance-runner",
  "projectType": "library",
  "tags": [
    "boundary:framework",
    "language:typescript",
    "layer:conformance-runner"
  ],
  "targets": {
    "conformance": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["kernel-interop-grpc"],
          "target": "codegen",
          "params": "ignore"
        },
        {
          "projects": ["host-repl"],
          "target": "build",
          "params": "ignore"
        }
      ],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/conformance-runner",
        "command": "bun ./src/framework-typescript-conformance.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/framework/implementations/typescript/conformance-runner"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/conformance-runner",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["kernel-interop-grpc"],
          "target": "codegen",
          "params": "ignore"
        }
      ],
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts boundaries/framework/implementations/typescript/conformance-runner"
      }
    }
  }
}
