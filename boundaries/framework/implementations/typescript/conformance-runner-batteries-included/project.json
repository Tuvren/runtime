{
  "name": "framework-batteries-included-conformance-runner",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/framework/implementations/typescript/conformance-runner-batteries-included",
  "projectType": "library",
  "tags": [
    "boundary:framework",
    "language:typescript",
    "layer:conformance-runner"
  ],
  "implicitDependencies": ["framework-typescript-conformance-adapter"],
  "targets": {
    "conformance": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "^production",
        "conformanceEngine",
        "{workspaceRoot}/boundaries/framework/conformance/**/*",
        "{workspaceRoot}/boundaries/framework/implementations/*/conformance-adapter/**/*"
      ],
      "dependsOn": [
        {
          "projects": ["framework-typescript-conformance-adapter"],
          "target": "build-batteries-included",
          "params": "ignore"
        }
      ],
      "options": {
        "cwd": ".",
        "command": "bun tools/conformance/runner/run.ts --adapter boundaries/framework/implementations/typescript/conformance-adapter/adapter-batteries-included.json --summary-only"
      }
    }
  }
}
