{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": [
        "../../../../shared/contracts/core-types/implementations/typescript/src/index.ts"
      ],
      "@tuvren/stream-core": ["./src/index.ts"],
      "@tuvren/event-stream": [
        "../../../contracts/event-stream/implementations/typescript/src/index.ts"
      ],
      "@tuvren/runtime-api": [
        "../../../contracts/runtime-api/implementations/typescript/src/index.ts"
      ],
      "@tuvren/runtime-api/events": [
        "../../../contracts/runtime-api/implementations/typescript/src/events.ts"
      ]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "smoke/**/*.ts",
    "../../../contracts/event-stream/implementations/typescript/src/**/*.ts",
    "../../../contracts/runtime-api/implementations/typescript/src/**/*.ts",
    "../../../../shared/contracts/core-types/implementations/typescript/src/**/*.ts"
  ]
}
