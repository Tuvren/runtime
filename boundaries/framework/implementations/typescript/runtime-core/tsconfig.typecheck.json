{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@kraken/shared-core-types": [
        "../../../../shared/contracts/core-types/src/index.ts"
      ],
      "@kraken/framework-runtime-api": [
        "../../../contracts/runtime-api/src/index.ts"
      ],
      "@kraken/framework-driver-api": [
        "../../../contracts/driver-api/src/index.ts"
      ],
      "@kraken/kernel-contract-protocol": [
        "../../../../kernel/contracts/protocol/src/index.ts"
      ],
      "@kraken/framework-runtime-core": ["./src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../../../contracts/runtime-api/src/**/*.ts",
    "../../../contracts/driver-api/src/**/*.ts",
    "../../../../kernel/contracts/protocol/src/**/*.ts",
    "../../../../shared/contracts/core-types/src/**/*.ts"
  ]
}
