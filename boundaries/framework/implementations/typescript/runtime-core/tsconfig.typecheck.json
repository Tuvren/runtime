{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": [
        "../../../../shared/contracts/core-types/src/index.ts"
      ],
      "@tuvren/runtime-api": ["../../../contracts/runtime-api/src/index.ts"],
      "@tuvren/runtime-api/events": [
        "../../../contracts/runtime-api/src/events.ts"
      ],
      "@tuvren/runtime-api/execution": [
        "../../../contracts/runtime-api/src/execution.ts"
      ],
      "@tuvren/runtime-api/provider": [
        "../../../contracts/runtime-api/src/provider.ts"
      ],
      "@tuvren/runtime-api/tools": [
        "../../../contracts/runtime-api/src/tools.ts"
      ],
      "@tuvren/driver-api": ["../../../contracts/driver-api/src/index.ts"],
      "@tuvren/kernel-protocol": [
        "../../../../kernel/contracts/protocol/src/index.ts"
      ],
      "@tuvren/runtime-core": ["./src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../../../contracts/runtime-api/src/**/*.ts",
    "../../../contracts/driver-api/src/**/*.ts",
    "../../../../kernel/contracts/protocol/src/**/*.ts",
    "../../../../shared/contracts/core-types/src/**/*.ts"
  ]
}
