{
  "name": "framework-runtime-core",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/framework/implementations/typescript/runtime-core",
  "sourceRoot": "boundaries/framework/implementations/typescript/runtime-core/src",
  "projectType": "library",
  "implicitDependencies": ["kernel-interop-grpc"],
  "tags": ["boundary:framework", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["kernel-interop-grpc"],
          "target": "codegen",
          "params": "ignore"
        },
        "^build"
      ],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "exports-smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "command": "bun test ./smoke/package-exports.ts"
      }
    },
    "bench": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "command": "bun bench/runtime-boundary.bench.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/framework/implementations/typescript/runtime-core"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["kernel-interop-grpc"],
          "target": "codegen",
          "params": "ignore"
        }
      ],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["kernel-interop-grpc"],
          "target": "codegen",
          "params": "ignore"
        },
        "^build"
      ],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "command": "bunx --bun tsc --project tsconfig.lib.json --noEmit --pretty false && bunx --bun tsc --project tsconfig.typecheck.json --noEmit --pretty false && bunx --bun tsc --project tsconfig.dts.json --noEmit --pretty false"
      }
    }
  }
}
