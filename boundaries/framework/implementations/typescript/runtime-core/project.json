{
  "name": "framework-runtime-core",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/framework/implementations/typescript/runtime-core",
  "sourceRoot": "boundaries/framework/implementations/typescript/runtime-core/src",
  "projectType": "library",
  "tags": ["boundary:framework", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "commands": [
          {
            "command": "bunx --bun tsup --config tsup.config.ts"
          },
          {
            "command": "bunx --bun tsc --project tsconfig.dts.json --pretty false"
          }
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime-core",
        "commands": [
          {
            "command": "bunx --bun tsc --project tsconfig.lib.json --noEmit --pretty false"
          },
          {
            "command": "bunx --bun tsc --project tsconfig.typecheck.json --noEmit --pretty false"
          }
        ],
        "parallel": false
      }
    }
  }
}
