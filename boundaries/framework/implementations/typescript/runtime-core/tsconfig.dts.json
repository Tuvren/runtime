{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@kraken/shared-core-types": [
        "../../../../shared/contracts/core-types/dist/index.d.ts"
      ],
      "@kraken/framework-runtime-api": [
        "../../../contracts/runtime-api/dist/index.d.ts"
      ],
      "@kraken/framework-driver-api": [
        "../../../contracts/driver-api/dist/index.d.ts"
      ],
      "@kraken/kernel-contract-protocol": [
        "../../../../kernel/contracts/protocol/dist/index.d.ts"
      ],
      "@kraken/framework-runtime-core": ["./src/index.ts"]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
