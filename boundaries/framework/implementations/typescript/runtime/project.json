{
  "name": "framework-runtime",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/framework/implementations/typescript/runtime",
  "sourceRoot": "boundaries/framework/implementations/typescript/runtime/src",
  "projectType": "library",
  "tags": ["boundary:framework", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "exports-smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime",
        "command": "bun test ./smoke/package-exports.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/framework/implementations/typescript/runtime"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime",
        "command": "bun test ./smoke/package-exports.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/framework/implementations/typescript/runtime",
        "command": "bunx --bun tsc --project tsconfig.lib.json --noEmit --pretty false && bunx --bun tsc --project tsconfig.typecheck.json --noEmit --pretty false && bunx --bun tsc --project tsconfig.dts.json --noEmit --pretty false"
      }
    }
  }
}
