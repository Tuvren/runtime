{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": [
        "../../../../shared/contracts/core-types/src/index.ts"
      ],
      "@tuvren/event-stream": ["../../../contracts/event-stream/src/index.ts"],
      "@tuvren/framework-testkit": ["../../../testkit/src/index.ts"],
      "@tuvren/stream-core": ["../stream-core/src/index.ts"],
      "@tuvren/stream-agui": ["./src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "smoke/**/*.ts",
    "../../../testkit/src/**/*.ts",
    "../../../contracts/event-stream/src/**/*.ts",
    "../stream-core/src/**/*.ts",
    "../../../../shared/contracts/core-types/src/**/*.ts"
  ]
}
