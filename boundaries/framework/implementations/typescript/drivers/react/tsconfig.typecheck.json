{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": [
        "../../../../../shared/contracts/core-types/src/index.ts"
      ],
      "@tuvren/runtime-api": [
        "../../../../../framework/contracts/runtime-api/src/index.ts"
      ],
      "@tuvren/runtime-api/events": [
        "../../../../../framework/contracts/runtime-api/src/events.ts"
      ],
      "@tuvren/runtime-api/execution": [
        "../../../../../framework/contracts/runtime-api/src/execution.ts"
      ],
      "@tuvren/runtime-api/provider": [
        "../../../../../framework/contracts/runtime-api/src/provider.ts"
      ],
      "@tuvren/runtime-api/tools": [
        "../../../../../framework/contracts/runtime-api/src/tools.ts"
      ],
      "@tuvren/driver-api": [
        "../../../../../framework/contracts/driver-api/src/index.ts"
      ],
      "@tuvren/provider-api": [
        "../../../../../providers/contracts/provider-api/src/index.ts"
      ],
      "@tuvren/runtime-core": ["../../runtime-core/src/index.ts"],
      "@tuvren/stream-agui": ["../../stream-agui/src/index.ts"],
      "@tuvren/stream-core": ["../../stream-core/src/index.ts"],
      "@tuvren/stream-sse": ["../../stream-sse/src/index.ts"],
      "@tuvren/driver-react": ["./src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "bench/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "../../../../../framework/contracts/runtime-api/src/**/*.ts",
    "../../../../../framework/contracts/driver-api/src/**/*.ts",
    "../../../../../providers/contracts/provider-api/src/**/*.ts",
    "../../../../../shared/contracts/core-types/src/**/*.ts",
    "../../runtime-core/src/**/*.ts",
    "../../runtime-core/test/**/*.ts",
    "../../stream-agui/src/**/*.ts",
    "../../stream-core/src/**/*.ts",
    "../../stream-sse/src/**/*.ts"
  ]
}
