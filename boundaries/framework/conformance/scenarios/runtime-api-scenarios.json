  "recover-staged-result": {
    "operation": "runtime.recover-result",
    "stagedObject": {
      "taskId": "tool-search",
      "objectType": "message",
      "payload": {
        "role": "tool",
        "parts": [
          {
            "type": "tool_result",
            "callId": "call-search",
            "name": "search",
            "output": { "ok": true }
          }
        ]
      }
    }
  },
