{
  "completed-tool-turn": {
    "operation": "event-stream.completed-tool-turn",
    "prompt": "Emit a completed event stream from implementation runtime logic.",
    "providerResponses": [
      {
        "finishReason": "tool_call",
        "parts": [
          {
            "type": "tool_call",
            "callId": "call-search",
            "name": "search",
            "input": { "query": "event stream measurement" }
          }
        ]
      },
      {
        "finishReason": "stop",
        "parts": [{ "type": "text", "text": "event stream turn completed" }]
      }
    ],
    "toolResult": { "ok": true, "source": "shared event stream scenario" }
  },
  "failed-provider-turn": {
    "operation": "event-stream.failed-provider-turn",
    "prompt": "Emit a failed event stream from implementation driver logic.",
    "providerResponses": [
      {
        "finishReason": "error",
        "parts": [{ "type": "text", "text": "provider failure" }]
      }
    ]
  },
  "paused-approval-turn": {
    "operation": "event-stream.paused-approval-turn",
    "prompt": "Emit a paused approval stream from implementation runtime logic.",
    "providerResponses": [
      {
        "finishReason": "tool_call",
        "parts": [
          {
            "type": "tool_call",
            "callId": "call-email",
            "name": "email",
            "input": { "to": "team@example.com" }
          }
        ]
      }
    ],
    "toolResult": { "sent": true }
  },
  "resumed-approval-turn": {
    "operation": "event-stream.resumed-approval-turn",
    "prompt": "Pause and resume the approval stream from implementation runtime logic.",
    "providerResponses": [
      {
        "finishReason": "tool_call",
        "parts": [
          {
            "type": "tool_call",
            "callId": "call-email",
            "name": "email",
            "input": { "to": "team@example.com" }
          }
        ]
      },
      {
        "finishReason": "stop",
        "parts": [{ "type": "text", "text": "approval resumed from shared scenario" }]
      }
    ],
    "approvalDecisions": [{ "callId": "call-email", "type": "approve" }],
    "finalText": "approval resumed from shared scenario",
    "toolResult": { "sent": true }
  }
}
