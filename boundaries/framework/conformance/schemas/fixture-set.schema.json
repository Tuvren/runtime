          "timestamp": { "type": "integer" }
        },
        "additionalProperties": true
      }
    },
    "failedTurn": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "timestamp"],
        "properties": {
          "type": { "type": "string" },
          "timestamp": { "type": "integer" }
        },
        "additionalProperties": true
      }
    },
    "pausedTurn": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "timestamp"],
        "properties": {
          "type": { "type": "string" },
          "timestamp": { "type": "integer" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
