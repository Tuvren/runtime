{
  "planId": "tuvren.framework.runtime-api.lifecycle",
  "planVersion": "0.1.0",
  "packetId": "tuvren.shared.core",
  "applicability": {
    "capabilities": ["framework.runtime-api"]
  },
  "scenarios": {
    "runtime-api-scenarios": "../scenarios/runtime-api-scenarios.json"
  },
  "checks": [
    {
      "checkId": "runtime-api.execute-turn.lifecycle",
      "operation": "runtime.execute-turn",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.completed-turn" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.runtime.phase",
          "equals": "completed"
        }
      ],
      "evidence": ["runtime.phase", "runtime.eventCount"]
    },
    {
      "checkId": "runtime-api.cancel-execution.failure",
      "operation": "runtime.cancel-execution",
      "steps": [
        {
          "stepId": "cancel",
          "operation": "runtime.cancel-execution",
          "controls": { "deadlineMs": 1000, "cancelAfterEvent": "turn.start" }
        }
      ],
      "assertions": [
        {
          "kind": "errorEnvelope",
          "path": "$.state.trace.cancel.result.error"
        }
      ],
      "evidence": ["trace.cancel.result.error.code"]
    },
    {
      "checkId": "runtime-api.approval-resolve.paused-resume",
      "operation": "runtime.approval-resolve",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.paused-turn-resume" },
      "steps": [
        {
          "stepId": "approval",
          "operation": "runtime.approval-resolve",
          "input": { "scenarioPath": "$.paused-turn-resume" }
        }
      ],
      "assertions": [
        {
          "kind": "stateField",
          "field": "$.trace.approval.evidence.approval.pausedPhase",
          "equals": "paused"
        },
        {
          "kind": "stateField",
          "field": "$.trace.approval.evidence.approval.resumedPhase",
          "equals": "completed"
        }
      ],
      "evidence": [
        "trace.approval.evidence.approval.pausedPhase",
        "trace.approval.evidence.approval.resumedPhase"
      ]
    },
    {
      "checkId": "runtime-api.branch-create.recovery",
      "operation": "runtime.branch-create",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.branch-from-completed-head" },
      "steps": [
        {
          "stepId": "branch",
          "operation": "runtime.branch-create",
          "input": { "scenarioPath": "$.branch-from-completed-head" }
        }
      ],
      "assertions": [
        {
          "kind": "stateField",
          "field": "$.trace.branch.state.branch.completedTurnPhase",
          "equals": "completed"
        },
        {
          "kind": "stateField",
          "field": "$.trace.branch.state.branch.sourceMessageCount",
          "equals": 2
        },
        {
          "kind": "stateField",
          "field": "$.trace.branch.state.branch.sourceHeadTurnNodeHash",
          "matches": "^[a-f0-9]{64}$"
        },
        {
          "kind": "stateField",
          "field": "$.trace.branch.state.branch.createdHeadTurnNodeHash",
          "matches": "^[a-f0-9]{64}$"
        }
      ],
      "evidence": [
        "trace.branch.state.branch.createdBranchId",
        "trace.branch.state.branch.sourceBranchId",
        "trace.branch.state.branch.completedTurnPhase",
        "trace.branch.state.branch.sourceMessageCount",
        "trace.branch.state.branch.createdHeadTurnNodeHash",
        "trace.branch.state.branch.sourceHeadTurnNodeHash"
      ]
    },
    {
      "checkId": "runtime-api.context-transform.shared-summary",
      "operation": "runtime.context-transform",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.context-transform-append-summary" },
      "steps": [
        {
          "stepId": "context",
          "operation": "runtime.context-transform",
          "input": { "scenarioPath": "$.context-transform-append-summary" }
        }
      ],
      "assertions": [
        {
          "kind": "stateField",
          "field": "$.trace.context.evidence.context.messageCount",
          "equals": 3
        },
        {
          "kind": "stateField",
          "field": "$.trace.context.evidence.context.summaryText",
          "equals": "Shared context engineering summary."
        },
        {
          "kind": "stateField",
          "field": "$.trace.context.evidence.runtime.phase",
          "equals": "completed"
        }
      ],
      "evidence": [
        "trace.context.evidence.context.messageCount",
        "trace.context.evidence.context.summaryText",
        "trace.context.evidence.runtime.phase"
      ]
    },
    {
      "checkId": "runtime-api.recover-result.staged-result",
      "operation": "runtime.recover-result",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.recover-staged-result" },
      "steps": [
        {
          "stepId": "recovery",
          "operation": "runtime.recover-result",
          "input": { "scenarioPath": "$.recover-staged-result" }
        }
      ],
      "assertions": [
        {
          "kind": "stateField",
          "field": "$.trace.recovery.evidence.recovery.uncommittedStagedResults",
          "equals": 1
        },
        {
          "kind": "stateField",
          "field": "$.trace.recovery.evidence.recovery.firstTaskId",
          "equals": "tool-search"
        },
        {
          "kind": "stateField",
          "field": "$.trace.recovery.evidence.recovery.firstObjectType",
          "equals": "message"
        }
      ],
      "evidence": [
        "trace.recovery.evidence.recovery.uncommittedStagedResults",
        "trace.recovery.evidence.recovery.firstTaskId",
        "trace.recovery.evidence.recovery.firstObjectType",
        "trace.recovery.evidence.recovery.lastTurnNodeHash"
      ]
    }
  ]
}
