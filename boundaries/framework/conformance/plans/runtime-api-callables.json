{
  "planId": "tuvren.framework.runtime-api.callables",
  "planVersion": "0.2.0",
  "packetId": "tuvren.shared.core",
  "applicability": {
    "capabilities": ["framework.runtime-api"]
  },
  "scenarios": {
    "runtime-api-scenarios": "../scenarios/runtime-api-scenarios.json"
  },
  "checks": [
    {
      "checkId": "runtime-callable.provider-generate",
      "operation": "runtime.provider-generate",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.provider-generate-text" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.provider.generate.callCount",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.provider.generate.response.parts.0.text",
          "equals": "generated from shared scenario"
        },
        {
          "kind": "resultField",
          "field": "$.provider.generate.response.finishReason",
          "equals": "stop"
        }
      ],
      "evidence": [
        "provider.generate.callCount",
        "provider.generate.response.parts.0.text",
        "provider.generate.response.finishReason"
      ]
    },
    {
      "checkId": "runtime-callable.provider-stream",
      "operation": "runtime.provider-stream",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.provider-stream-text" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.provider.stream.callCount",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.provider.stream.emittedEventTypes",
          "contains": "text.delta"
        },
        {
          "kind": "resultField",
          "field": "$.provider.stream.response.parts.0.text",
          "equals": "streamed from shared scenario"
        },
        {
          "kind": "resultField",
          "field": "$.provider.stream.chunkTypes",
          "equals": ["text_delta", "finish"]
        }
      ],
      "evidence": [
        "provider.stream.callCount",
        "provider.stream.emittedEventTypes",
        "provider.stream.response.parts.0.text",
        "provider.stream.chunkTypes"
      ]
    },
    {
      "checkId": "runtime-callable.tool-execute",
      "operation": "runtime.tool-execute",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.tool-execute-search" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.tool.execution.callCount",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.tool.execution.inputs.0.query",
          "equals": "shared docs"
        },
        {
          "kind": "resultField",
          "field": "$.tool.execution.outputs.0.source",
          "equals": "shared scenario"
        },
        {
          "kind": "stateField",
          "field": "$.toolExecution.status.phase",
          "equals": "completed"
        },
        {
          "kind": "stateField",
          "field": "$.toolExecution.status.manifest.toolResults.total",
          "equals": 1
        }
      ],
      "evidence": [
        "tool.execution.callCount",
        "tool.execution.inputs.0.query",
        "tool.execution.outputs.0.source",
        "toolExecution.status.phase",
        "toolExecution.status.manifest.toolResults.total"
      ]
    },
    {
      "checkId": "runtime-callable.approval-resolve",
      "operation": "runtime.approval-resolve",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.paused-turn-resume" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.approval.pausedPhase",
          "equals": "paused"
        },
        {
          "kind": "resultField",
          "field": "$.approval.resumedPhase",
          "equals": "completed"
        },
        {
          "kind": "resultField",
          "field": "$.tool.execution.executedNames",
          "equals": ["search", "email"]
        },
        {
          "kind": "resultField",
          "field": "$.approval.decisions.0.type",
          "equals": "approve"
        }
      ],
      "evidence": [
        "approval.pausedPhase",
        "approval.resumedPhase",
        "tool.execution.executedNames",
        "approval.decisions.0.type"
      ]
    },
    {
      "checkId": "runtime-callable.validation-failure",
      "operation": "runtime.validate-structured-output",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.structured-validation-failure" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.validation.resolutionType",
          "equals": "fail"
        }
      ],
      "evidence": ["validation.resolutionType"]
    },
    {
      "checkId": "runtime-callable.timeout-retry-cancellation-idempotency",
      "operation": "runtime.cancel-execution",
      "controls": { "deadlineMs": 1000, "cancelAfterEvent": "turn.start" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.cancellation.observedEventType",
          "equals": "turn.start"
        },
        {
          "kind": "resultField",
          "field": "$.cancellation.observedEventIndex",
          "equals": 0
        },
        {
          "kind": "resultField",
          "field": "$.cancellation.cancelInvocations",
          "equals": 2
        },
        {
          "kind": "resultField",
          "field": "$.cancellation.errorEventCount",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.runtime.phase",
          "equals": "failed"
        }
      ],
      "evidence": [
        "cancellation.observedEventType",
        "cancellation.observedEventIndex",
        "cancellation.cancelInvocations",
        "cancellation.errorEventCount",
        "runtime.phase"
      ]
    },
    {
      "checkId": "runtime-api-handle-terminal-value.complete",
      "operation": "runtime.handle-terminal-value",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.handle-terminal-value-complete" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.status",
          "equals": "completed"
        },
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.finalAssistantMessage.parts.0.text",
          "equals": "Terminal complete."
        }
      ]
    },
    {
      "checkId": "runtime-api-handle-terminal-value.failure-resolves",
      "operation": "runtime.handle-terminal-value",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.handle-terminal-value-failure" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.status",
          "equals": "failed"
        }
      ]
    },
    {
      "checkId": "runtime-api-handle-terminal-value.cancel-rejects",
      "operation": "runtime.handle-terminal-value",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.handle-terminal-value-cancelled" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.rejected",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.error.code",
          "equals": "execution_cancelled"
        }
      ]
    },
    {
      "checkId": "runtime-api-handle-terminal-value.idempotent",
      "operation": "runtime.handle-terminal-value",
      "scenario": "runtime-api-scenarios",
      "input": { "scenarioPath": "$.handle-terminal-value-idempotent" },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.allCompleted",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.callCount",
          "equals": 3
        },
        {
          "kind": "resultField",
          "field": "$.handle.awaitResult.resultsIdentical",
          "equals": true
        }
      ]
    }
  ]
}
