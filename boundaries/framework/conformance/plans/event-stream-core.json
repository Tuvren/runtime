{
  "planId": "tuvren.framework.event-stream.core",
  "planVersion": "0.1.0",
  "packetId": "tuvren.shared.core",
  "applicability": {
    "capabilities": ["framework.event-stream"]
  },
  "scenarios": {
    "event-stream-scenarios": "../scenarios/event-stream-scenarios.json"
  },
  "checks": [
    {
      "checkId": "event-stream.sse.projection",
      "operation": "event-stream.runtime-sse-projection",
      "scenario": "event-stream-scenarios",
      "input": {
        "scenarioPath": "$.completed-tool-turn"
      },
      "assertions": [
        {
          "kind": "eventSequence",
          "equals": [
            "turn.start",
            "state.checkpoint",
            "state.snapshot",
            "iteration.start",
            "message.start",
            "tool_call.start",
            "tool_call.args_delta",
            "tool_call.done",
            "message.done",
            "tool.start",
            "tool.result",
            "state.checkpoint",
            "state.snapshot",
            "iteration.end",
            "iteration.start",
            "message.start",
            "text.delta",
            "text.done",
            "message.done",
            "state.checkpoint",
            "state.snapshot",
            "iteration.end",
            "state.checkpoint",
            "turn.end"
          ],
          "path": "$.event"
        },
        {
          "kind": "resultField",
          "field": "$.events.0.payload.type",
          "equals": "turn.start"
        },
        {
          "kind": "resultField",
          "field": "$.events.10.payload.output.source",
          "equals": "shared event stream scenario"
        }
      ],
      "evidence": ["events"]
    },
    {
      "checkId": "event-stream.sse.eager-subscription",
      "operation": "event-stream.runtime-sse-eager-subscription",
      "scenario": "event-stream-scenarios",
      "input": {
        "scenarioPath": "$.completed-tool-turn"
      },
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.firstDirectEvent.type",
          "equals": "turn.start"
        },
        {
          "kind": "resultField",
          "field": "$.events.0.event",
          "equals": "turn.start"
        }
      ]
    },
    {
      "checkId": "event-stream.agui.projection",
      "operation": "event-stream.runtime-agui-projection",
      "scenario": "event-stream-scenarios",
      "input": {
        "scenarioPath": "$.completed-tool-turn"
      },
      "assertions": [
        {
          "kind": "eventSequence",
          "equals": [
            "RUN_STARTED",
            "CUSTOM",
            "STATE_SNAPSHOT",
            "STEP_STARTED",
            "TOOL_CALL_START",
            "TOOL_CALL_ARGS",
            "TOOL_CALL_END",
            "CUSTOM",
            "CUSTOM",
            "TOOL_CALL_RESULT",
            "CUSTOM",
            "STATE_SNAPSHOT",
            "STEP_FINISHED",
            "STEP_STARTED",
            "TEXT_MESSAGE_START",
            "TEXT_MESSAGE_CONTENT",
            "TEXT_MESSAGE_END",
            "CUSTOM",
            "CUSTOM",
            "STATE_SNAPSHOT",
            "STEP_FINISHED",
            "CUSTOM",
            "RUN_FINISHED"
          ],
          "path": "$.type"
        },
        {
          "kind": "resultField",
          "field": "$.events.0.rawEvent.type",
          "equals": "turn.start"
        },
        {
          "kind": "resultField",
          "field": "$.warnings",
          "equals": [
            {
              "code": "agui_state_checkpoint_custom_fallback"
            },
            {
              "code": "agui_message_done_custom_fallback"
            },
            {
              "code": "agui_tool_execution_custom_fallback"
            }
          ]
        }
      ],
      "evidence": ["events"]
    },
    {
      "checkId": "event-stream.agui.failed-turn-error-projection",
      "operation": "event-stream.runtime-agui-projection",
      "scenario": "event-stream-scenarios",
      "input": {
        "scenarioPath": "$.failed-provider-turn"
      },
      "assertions": [
        {
          "kind": "eventSequence",
          "equals": [
            "RUN_STARTED",
            "CUSTOM",
            "STATE_SNAPSHOT",
            "STEP_STARTED",
            "CUSTOM",
            "STATE_SNAPSHOT",
            "STEP_FINISHED",
            "CUSTOM",
            "RUN_ERROR"
          ],
          "path": "$.type"
        },
        {
          "kind": "resultField",
          "field": "$.events.8.rawEvent.type",
          "equals": "error"
        },
        {
          "kind": "resultField",
          "field": "$.events.8.rawEvent.error.code",
          "matches": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        }
      ],
      "evidence": ["events"]
    },
    {
      "checkId": "event-stream.agui.paused-turn-fallback",
      "operation": "event-stream.runtime-agui-projection",
      "scenario": "event-stream-scenarios",
      "input": {
        "scenarioPath": "$.paused-approval-turn"
      },
      "assertions": [
        {
          "kind": "eventSequence",
          "equals": [
            "RUN_STARTED",
            "CUSTOM",
            "STATE_SNAPSHOT",
            "STEP_STARTED",
            "TOOL_CALL_START",
            "TOOL_CALL_ARGS",
            "TOOL_CALL_END",
            "CUSTOM",
            "CUSTOM",
            "STATE_SNAPSHOT",
            "STEP_FINISHED",
            "CUSTOM",
            "CUSTOM",
            "RUN_FINISHED"
          ],
          "path": "$.type"
        },
        {
          "kind": "resultField",
          "field": "$.events.11.rawEvent.type",
          "equals": "approval.requested"
        },
        {
          "kind": "resultField",
          "field": "$.warnings",
          "equals": [
            {
              "code": "agui_state_checkpoint_custom_fallback"
            },
            {
              "code": "agui_message_done_custom_fallback"
            },
            {
              "code": "agui_approval_custom_fallback"
            },
            {
              "code": "agui_paused_turn_coerced_to_run_finished"
            }
          ]
        }
      ],
      "evidence": ["events"]
    }
  ]
}
