{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/runtime-api/ApprovalDecision.json",
  "type": "object",
  "properties": {
    "callId": {
      "$ref": "https://tuvren.dev/schemas/framework/runtime-api/NonEmptyString.json"
    },
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "approve"
        },
        {
          "type": "string",
          "const": "edit"
        },
        {
          "type": "string",
          "const": "reject"
        },
        {
          "type": "string"
        }
      ]
    },
    "editedInput": {},
    "message": {
      "type": "string"
    }
  },
  "required": ["callId", "type"],
  "unevaluatedProperties": {
    "not": {}
  }
}
