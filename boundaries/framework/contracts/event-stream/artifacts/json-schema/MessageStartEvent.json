{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/event-stream/MessageStartEvent.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "message.start"
    },
    "messageId": {
      "$ref": "https://tuvren.dev/schemas/framework/event-stream/NonEmptyString.json"
    },
    "role": {
      "anyOf": [
        {
          "type": "string",
          "const": "assistant"
        },
        {
          "type": "string",
          "const": "tool"
        }
      ]
    }
  },
  "required": ["type", "messageId", "role"],
  "allOf": [
    {
      "$ref": "https://tuvren.dev/schemas/framework/event-stream/BaseEvent.json"
    }
  ],
  "unevaluatedProperties": {
    "not": {}
  }
}
