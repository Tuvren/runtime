{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/event-stream/TurnEndEvent.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "turn.end"
    },
    "turnId": {
      "$ref": "https://tuvren.dev/schemas/framework/event-stream/NonEmptyString.json"
    },
    "status": {
      "anyOf": [
        {
          "type": "string",
          "const": "completed"
        },
        {
          "type": "string",
          "const": "paused"
        },
        {
          "type": "string",
          "const": "failed"
        }
      ]
    }
  },
  "required": ["type", "turnId", "status"],
  "allOf": [
    {
      "$ref": "https://tuvren.dev/schemas/framework/event-stream/BaseEvent.json"
    }
  ],
  "unevaluatedProperties": {
    "not": {}
  }
}
