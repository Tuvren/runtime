{
  "name": "framework-event-stream",
  "$schema": "../../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/framework/contracts/event-stream/implementations/typescript",
  "sourceRoot": "boundaries/framework/contracts/event-stream/implementations/typescript/src",
  "projectType": "library",
  "tags": ["boundary:framework", "layer:contract"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/framework/contracts/event-stream/implementations/typescript",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/boundaries/framework/contracts/event-stream/artifacts/json-schema"
      ],
      "options": {
        "cwd": "boundaries/framework/contracts/event-stream",
        "command": "bunx --bun tsp compile ./spec/typespec --pretty false && bunx --bun @biomejs/biome check --write ./artifacts"
      },
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/boundaries/framework/contracts/event-stream/spec/**/*",
        "{workspaceRoot}/boundaries/framework/contracts/event-stream/artifacts/**/*"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/framework/contracts/event-stream/implementations/typescript",
        "command": "bun test"
      }
    },
    "exports-smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/framework/contracts/event-stream/implementations/typescript",
        "command": "bun test ./smoke/package-exports.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/framework/contracts/event-stream/implementations/typescript"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts boundaries/framework/contracts/event-stream/implementations/typescript"
      }
    }
  }
}
