{
  "name": "framework-tool-contracts",
  "$schema": "../../../../../../node_modules/nx/schemas/project-schema.json",
  "root": "boundaries/framework/contracts/tool-contracts/implementations/typescript",
  "sourceRoot": "boundaries/framework/contracts/tool-contracts/implementations/typescript/src",
  "projectType": "library",
  "tags": ["boundary:framework", "layer:contract"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "boundaries/framework/contracts/tool-contracts/implementations/typescript",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/boundaries/framework/contracts/tool-contracts/artifacts/json-schema",
        "{workspaceRoot}/boundaries/framework/contracts/tool-contracts/artifacts/openapi"
      ],
      "options": {
        "cwd": "boundaries/framework/contracts/tool-contracts",
        "command": "bunx --bun tsp compile ./spec/typespec --pretty false && bunx --bun @biomejs/biome check --write ./artifacts"
      },
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/boundaries/framework/contracts/tool-contracts/spec/**/*",
        "{workspaceRoot}/boundaries/framework/contracts/tool-contracts/artifacts/**/*"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "boundaries/framework/contracts/tool-contracts/implementations/typescript",
        "command": "bun test"
      },
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/boundaries/framework/contracts/tool-contracts/artifacts/**/*"
      ]
    },
    "exports-smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "boundaries/framework/contracts/tool-contracts/implementations/typescript",
        "command": "bun test ./smoke/package-exports.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check boundaries/framework/contracts/tool-contracts/implementations/typescript"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts boundaries/framework/contracts/tool-contracts/implementations/typescript"
      }
    }
  }
}
