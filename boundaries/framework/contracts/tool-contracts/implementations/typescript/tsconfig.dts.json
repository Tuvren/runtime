{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/core-types": [
        "../../../../../shared/contracts/core-types/implementations/typescript/dist/index.d.ts"
      ],
      "@tuvren/runtime-api": [
        "../../../runtime-api/implementations/typescript/dist/index.d.ts"
      ],
      "@tuvren/runtime-api/tools": [
        "../../../runtime-api/implementations/typescript/dist/tools.d.ts"
      ],
      "@tuvren/tool-contracts": ["./src/index.ts"]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
