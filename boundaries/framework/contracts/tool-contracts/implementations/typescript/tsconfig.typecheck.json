{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core": [
        "../../../../../shared/contracts/core/implementations/typescript/src/index.ts"
      ],
      "@tuvren/core-types": [
        "../../../../../shared/contracts/core-types/implementations/typescript/src/index.ts"
      ],
      "@tuvren/core/driver": [
        "../../../../../shared/contracts/core/implementations/typescript/src/driver/index.ts"
      ],
      "@tuvren/core/errors": [
        "../../../../../shared/contracts/core/implementations/typescript/src/errors/index.ts"
      ],
      "@tuvren/core/events": [
        "../../../../../shared/contracts/core/implementations/typescript/src/events/index.ts"
      ],
      "@tuvren/core/execution": [
        "../../../../../shared/contracts/core/implementations/typescript/src/execution/index.ts"
      ],
      "@tuvren/core/extensions": [
        "../../../../../shared/contracts/core/implementations/typescript/src/extensions/index.ts"
      ],
      "@tuvren/core/messages": [
        "../../../../../shared/contracts/core/implementations/typescript/src/messages/index.ts"
      ],
      "@tuvren/core/provider": [
        "../../../../../shared/contracts/core/implementations/typescript/src/provider/index.ts"
      ],
      "@tuvren/core/tools": [
        "../../../../../shared/contracts/core/implementations/typescript/src/tools/index.ts"
      ],
      "@tuvren/kernel-protocol": [
        "../../../../../kernel/contracts/protocol/implementations/typescript/src/index.ts"
      ],
      "@tuvren/runtime-api": [
        "../../../runtime-api/implementations/typescript/src/index.ts"
      ],
      "@tuvren/runtime-api/tools": [
        "../../../runtime-api/implementations/typescript/src/tools.ts"
      ],
      "@tuvren/tool-contracts": ["./src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../../../../../kernel/contracts/protocol/implementations/typescript/src/**/*.ts",
    "../../../runtime-api/implementations/typescript/src/**/*.ts",
    "../../../../../shared/contracts/core-types/implementations/typescript/src/**/*.ts"
