{
  "name": "tuvren-runtime",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "workspaces": [
    "boundaries/*/contracts/*",
    "boundaries/*/implementations/*/*",
    "boundaries/*/testkit",
    "boundaries/framework/implementations/typescript/drivers/*"
  ],
  "scripts": {
    "lint": "bunx --bun @biomejs/biome check .",
    "format": "bunx --bun @biomejs/biome check --write .",
    "nx": "bun ./tools/run-nx.mjs",
    "typecheck": "bun run nx run-many -t typecheck",
    "conformance": "bun run nx run-many -t conformance -p kernel-typescript-conformance-runner,kernel-rust-conformance-runner,framework-typescript-conformance-runner,providers-typescript-conformance-runner",
    "codegen": "bun run nx run-many -t codegen -p framework-tool-contracts,provider-api,telemetry-semconv,compatibility-reporting,kernel-interop-grpc",
    "interop-smoke": "bun run nx run-many -t interop-smoke -p kernel-interop-grpc,kernel-rust-grpc-service",
    "verify": "bun tools/scripts/verify.ts",
    "release-check": "bun tools/scripts/release-check.ts",
    "graph": "bun run nx graph"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nx/js": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@typespec/compiler": "1.11.0",
    "@typespec/events": "0.81.0",
    "@typespec/http": "1.11.0",
    "@typespec/json-schema": "1.11.0",
    "@typespec/openapi": "1.11.0",
    "@typespec/openapi3": "1.11.0",
    "@typespec/rest": "0.81.0",
    "@typespec/sse": "0.81.0",
    "@typespec/streams": "0.81.0",
    "@typespec/versioning": "0.81.0",
    "ajv": "8.18.0",
    "cbor-x": "1.6.4",
    "cddl": "0.20.1",
    "nx": "22.6.3",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "ultracite": "7.4.2"
  }
}
