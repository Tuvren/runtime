{
  "name": "tuvren-runtime",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "workspaces": [
    "boundaries/*/contracts/*",
    "boundaries/*/implementations/*/*",
    "boundaries/*/testkit",
    "boundaries/framework/implementations/typescript/drivers/*"
  ],
  "scripts": {
    "lint": "bunx --bun @biomejs/biome check .",
    "format": "bunx --bun @biomejs/biome check --write .",
    "nx": "bun ./tools/run-nx.mjs",
    "typecheck": "bun run nx run-many -t typecheck",
    "verify": "bun tools/scripts/verify.ts",
    "release-check": "bun tools/scripts/release-check.ts",
    "graph": "bun run nx graph"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nx/js": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "cbor-x": "1.6.4",
    "nx": "22.6.3",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "ultracite": "7.4.2"
  }
}
