{
  "name": "tuvren-runtime",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "workspaces": [
    "boundaries/*/contracts/*/implementations/*",
    "boundaries/*/implementations/*/*",
    "boundaries/framework/implementations/typescript/drivers/*"
  ],
  "scripts": {
    "lint": "bunx --bun @biomejs/biome check .",
    "format": "bunx --bun @biomejs/biome check --write .",
    "nx": "bun ./tools/run-nx.mjs",
    "typecheck": "bun run nx run-many -t typecheck",
    "conformance": "bun run nx run-many -t conformance -p kernel-typescript-conformance-runner,kernel-typescript-sqlite-conformance-runner,kernel-typescript-postgres-conformance-runner,kernel-rust-conformance-runner,framework-typescript-conformance-runner,framework-rust-conformance-runner,providers-typescript-conformance-runner",
    "compatibility:evidence": "bun run nx run compatibility-reporting:evidence-refresh --skipNxCache",
    "codegen": "bun run docs:authority-freeze:check && bun run portability:check && bun run docs:af-gap-plan:check && bun tools/scripts/authority-packet/validate-authority-packets.ts && bun tools/conformance/plan-compiler/validate-plans.ts && bun tools/conformance/adapter-protocol/validate-adapter-protocol.ts && bun tools/conformance/meta-conformance/run.ts && bun tools/conformance/vocabulary/validate-vocabulary.ts && bun tools/scripts/authority-guardrails/authority-guardrails.ts && bun run nx run-many -t codegen -p shared-core-types,framework-runtime-api,framework-event-stream,framework-event-stream-sse,framework-driver-api,framework-tool-contracts,provider-api,telemetry-semconv,compatibility-reporting,kernel-interop-grpc",
    "interop-smoke": "bun run nx run-many -t interop-smoke -p kernel-interop-grpc,kernel-rust-grpc-service,host-repl --parallel=1",
    "proving-host:interop-smoke": "bun run nx run host-repl:interop-smoke --skipNxCache --excludeTaskDependencies",
    "proving-host:scenario-sqlite": "bun run nx run host-repl:scenario-sqlite",
    "proving-host:scenario-postgres": "bun run nx run host-repl:scenario-postgres",
    "docs:authority-freeze": "bun tools/scripts/docs-authority-freeze-gate.ts",
    "docs:authority-freeze:check": "bun tools/scripts/docs-authority-freeze-gate.ts --check",
    "docs:af-gap-plan": "bun tools/scripts/epic-af-conformance-gap-plan.ts",
    "docs:af-gap-plan:check": "bun tools/scripts/epic-af-conformance-gap-plan.ts --check",
    "portability:check": "bun tools/scripts/portability-gate.ts",
    "verify": "bun tools/scripts/verify.ts",
    "release-check": "bun tools/scripts/release-check.ts",
    "graph": "bun run nx graph"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nx/js": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@typespec/compiler": "1.11.0",
    "@typespec/events": "0.81.0",
    "@typespec/http": "1.11.0",
    "@typespec/json-schema": "1.11.0",
    "@typespec/openapi": "1.11.0",
    "@typespec/openapi3": "1.11.0",
    "@typespec/rest": "0.81.0",
    "@typespec/sse": "0.81.0",
    "@typespec/streams": "0.81.0",
    "@typespec/versioning": "0.81.0",
    "ajv": "8.18.0",
    "cbor-x": "1.6.4",
    "cddl": "0.20.1",
    "nx": "22.6.3",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "ultracite": "7.4.2"
  }
}
