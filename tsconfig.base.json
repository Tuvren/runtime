{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@kraken/shared-core-types": [
        "./boundaries/shared/contracts/core-types/src/index.ts"
      ],
      "@kraken/kernel-contract-protocol": [
        "./boundaries/kernel/contracts/protocol/src/index.ts"
      ],
      "@kraken/framework-runtime-api": [
        "./boundaries/framework/contracts/runtime-api/src/index.ts"
      ],
      "@kraken/framework-event-stream": [
        "./boundaries/framework/contracts/event-stream/src/index.ts"
      ],
      "@kraken/framework-tool-contracts": [
        "./boundaries/framework/contracts/tool-contracts/src/index.ts"
      ],
      "@kraken/framework-driver-api": [
        "./boundaries/framework/contracts/driver-api/src/index.ts"
      ],
      "@kraken/provider-api": [
        "./boundaries/providers/contracts/provider-api/src/index.ts"
      ],
      "@kraken/framework-runtime-core": [
        "./boundaries/framework/implementations/typescript/runtime-core/src/index.ts"
      ],
      "@kraken/backend-memory": [
        "./boundaries/kernel/implementations/typescript/backend-memory/src/index.ts"
      ],
      "@kraken/backend-sqlite": [
        "./boundaries/kernel/implementations/typescript/backend-sqlite/src/index.ts"
      ],
      "@kraken/kernel-testkit": ["./boundaries/kernel/testkit/src/index.ts"]
    },
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true
  }
}
