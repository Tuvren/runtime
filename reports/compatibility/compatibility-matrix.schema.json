{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/reports/compatibility/compatibility-matrix.schema.json",
  "type": "object",
  "required": [
    "generatedAtMs",
    "sourceRevision",
    "suites",
    "implementations",
    "interop"
  ],
  "properties": {
    "generatedAtMs": {
      "type": "integer",
      "minimum": 0
    },
    "sourceRevision": {
      "type": "string",
      "minLength": 1
    },
    "suites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["suiteId", "suiteVersion", "boundary"],
        "properties": {
          "suiteId": { "type": "string" },
          "suiteVersion": { "type": "string" },
          "boundary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "implementations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["implementationId", "language", "version", "results"],
        "properties": {
          "implementationId": { "type": "string" },
          "language": { "type": "string" },
          "version": { "type": "string" },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "suiteId",
                "suiteVersion",
                "status",
                "evidencePath",
                "checkIds",
                "checkSummary"
              ],
              "properties": {
                "suiteId": { "type": "string" },
                "suiteVersion": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["pass", "fail"]
                },
                "evidencePath": { "type": "string" },
                "checkIds": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "checkSummary": {
                  "type": "object",
                  "required": ["failedChecks", "passedChecks", "totalChecks"],
                  "properties": {
                    "applicableChecks": { "type": "integer", "minimum": 0 },
                    "failedChecks": { "type": "integer", "minimum": 0 },
                    "nonApplicableChecks": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "passedChecks": { "type": "integer", "minimum": 0 },
                    "totalChecks": { "type": "integer", "minimum": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "interop": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pairId",
          "suiteId",
          "suiteVersion",
          "status",
          "evidencePath",
          "checkIds",
          "checkSummary"
        ],
        "properties": {
          "pairId": { "type": "string" },
          "suiteId": { "type": "string" },
          "suiteVersion": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "evidencePath": { "type": "string" },
          "checkIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "checkSummary": {
            "type": "object",
            "required": ["failedChecks", "passedChecks", "totalChecks"],
            "properties": {
              "applicableChecks": { "type": "integer", "minimum": 0 },
              "failedChecks": { "type": "integer", "minimum": 0 },
              "nonApplicableChecks": { "type": "integer", "minimum": 0 },
              "passedChecks": { "type": "integer", "minimum": 0 },
              "totalChecks": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
