{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": ["@nx/js/typescript"],
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "!{projectRoot}/dist/**/*",
      "!{projectRoot}/.tmp*/**/*",
      "!{projectRoot}/coverage/**/*",
      "!{projectRoot}/*.tsbuildinfo"
    ],
    "production": ["default"],
    "conformanceEngine": ["{workspaceRoot}/tools/conformance/**/*"]
  },
  "targetDefaults": {
    "codegen": {
      "cache": true,
      "//": "Baseline only. Every codegen target declares its own scoped inputs/outputs in project.json (project-level inputs REPLACE this default, they do not merge). Keep this default free of cross-boundary globs so a future un-scoped codegen target does not silently depend on unrelated boundaries.",
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/tools/generators/**/*",
        "{workspaceRoot}/tools/scripts/**/*",
        "{workspaceRoot}/devenv.nix",
        "{workspaceRoot}/devenv.lock"
      ]
    },
    "conformance": {
      "cache": true,
      "//": "Baseline only. Each conformance runner declares scoped inputs in project.json (own boundary assets + the shared conformanceEngine namedInput). Project-level inputs REPLACE this default. Do not add cross-boundary or root tests/** globs here; that re-introduces cross-boundary cache poisoning.",
      "inputs": ["default", "^production", "conformanceEngine"]
    },
    "interop-smoke": {
      "cache": false,
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/tools/scripts/**/*",
        "{workspaceRoot}/boundaries/*/interop/**/*",
        "{workspaceRoot}/boundaries/framework/implementations/typescript/runtime-core/package.json",
        "{workspaceRoot}/boundaries/framework/implementations/typescript/runtime-core/tsconfig.kernel-interop.generated.json",
        "{workspaceRoot}/bun.lock",
        "{workspaceRoot}/devenv.nix",
        "{workspaceRoot}/devenv.lock",
        "{workspaceRoot}/buf.yaml",
        "{workspaceRoot}/buf.gen.yaml"
      ]
    },
    "build": {
      "cache": true,
      "outputs": ["{projectRoot}/dist"],
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/rust-toolchain.toml",
        "{workspaceRoot}/devenv.nix",
        "{workspaceRoot}/devenv.lock"
      ]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/biome.jsonc",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/rust-toolchain.toml"
      ]
    },
    "test": {
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/rust-toolchain.toml",
        "{workspaceRoot}/devenv.nix",
        "{workspaceRoot}/devenv.lock",
        "{workspaceRoot}/boundaries/kernel/conformance/**/*",
        "{workspaceRoot}/boundaries/kernel/interop/**/*"
      ]
    },
    "typecheck": {
      "cache": true,
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/tsconfig.base.json",
        "{workspaceRoot}/tools/scripts/typecheck-project.ts",
        "{workspaceRoot}/tools/scripts/lib/command-runner.ts"
      ]
    }
  },
  "defaultBase": "master",
  "analytics": false
}
